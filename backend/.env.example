PORT=4000
NODE_ENV=development

# MongoDB Atlas — get free cluster at mongodb.com/atlas
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/finance_ai?retryWrites=true&w=majority

# Redis (Docker local)
REDIS_URL=redis://localhost:6379

# Kafka (Docker local)
KAFKA_BROKER=localhost:9092
KAFKA_TOPIC=transactions

# Groq — completely FREE, faster than OpenAI
# Sign up at console.groq.com → API Keys → Create key
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxx
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_FAST_MODEL=llama-3.1-8b-instant

# HuggingFace — free embeddings for RAG (Day 3)
# Sign up at huggingface.co → Settings → Access Tokens → New token
HUGGINGFACE_API_KEY=hf_xxxxxxxxxxxxxxxxxxxxxxxx

# Silence Kafka partitioner warning
KAFKAJS_NO_PARTITIONER_WARNING=1

# JWT — use a long random string (min 32 chars)
JWT_SECRET=your-super-secret-jwt-key-change-this-minimum-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-key-change-this-minimum-32-chars
JWT_EXPIRES_IN=7d

# AWS S3 — free tier 5GB
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_REGION=ap-south-1
AWS_S3_BUCKET=finance-ai-uploads

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173
