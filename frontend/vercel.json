{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://dried-baby-gst-enclosure.trycloudflare.com/api/:path*"
    },
    {
      "source": "/graphql",
      "destination": "https://dried-baby-gst-enclosure.trycloudflare.com/graphql"
    },
    {
      "source": "/socket.io/:path*",
      "destination": "https://dried-baby-gst-enclosure.trycloudflare.com/socket.io/:path*"
    }
  ]
}
