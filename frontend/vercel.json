{
  "functions": {
    "api/**": {
      "maxDuration": 300
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "http://13.127.82.107:4000/api/:path*"
    },
    {
      "source": "/graphql",
      "destination": "http://13.127.82.107:4000/graphql"
    },
    {
      "source": "/socket.io/:path*",
      "destination": "http://13.127.82.107:4000/socket.io/:path*"
    }
  ]
}
